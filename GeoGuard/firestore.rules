rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function sameTenant(tenantId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    function isSuperAdmin() {
      return hasRole('super_admin');
    }
    
    function isAdmin() {
      return hasAnyRole(['admin', 'super_admin']);
    }
    
    function isManager() {
      return hasAnyRole(['manager', 'admin', 'super_admin']);
    }
    
    // Users Collection
    match /users/{userId} {
      // Allow users to create their own account during signup
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['email', 'fullName', 'tenantId', 'role', 'isActive']);
      
      // Users can read their own data, data from users in the same tenant,
      // OR queries for initials checking during signup (before user document exists)
      allow read: if isOwner(userId) || 
                    (isAuthenticated() && sameTenant(resource.data.tenantId));
      
      // Allow limited queries for initials checking during signup (before user document exists)
      allow list: if isAuthenticated() && request.query.limit <= 1;
      
      // Users can update their own lastLoginAt field, admins can update everything
      allow update: if (isOwner(userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt'])) ||
                      (isAuthenticated() && 
                       sameTenant(resource.data.tenantId) && 
                       hasAnyRole(['admin', 'super_admin']));
      
      // Only admins can delete users
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      hasAnyRole(['admin', 'super_admin']);
    }
    
    // Tenants Collection
    match /tenants/{tenantId} {
      // Allow creation during organization registration
      allow create: if isAuthenticated() && 
                      request.resource.data.adminId == request.auth.uid;
      
      // Users in the tenant can read tenant data
      allow read: if isAuthenticated() && sameTenant(tenantId);
      
      // Only admins can update tenant settings
      allow update: if isAuthenticated() && 
                      sameTenant(tenantId) && 
                      hasAnyRole(['admin', 'super_admin']);
      
      // Only super admins can delete tenants
      allow delete: if isSuperAdmin();
    }
    
    // Invitations Collection
    match /invitations/{invitationId} {
      // Admins and managers can create invitations
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isManager();
      
      // Anyone can read (needed for signup validation)
      allow read: if true;
      
      // Anyone authenticated can update (needed for marking as used during signup)
      allow update: if isAuthenticated();
      
      // Admins and managers can delete invitations
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
    }
    
    // Locations Collection
    match /locations/{userId} {
      // Field personnel can create/update their own location
      allow create, update: if isOwner(userId) && 
                              isAuthenticated() && 
                              sameTenant(request.resource.data.tenantId);
      
      // Users in the tenant can read individual locations
      allow read: if isAuthenticated() && sameTenant(resource.data.tenantId);
      
      // Admins and managers can query all locations in their tenant
      allow list: if isAuthenticated() && isManager();
      
      // Location history cannot be deleted
      allow delete: if false;
    }
    
    // Geofences Collection
    match /geofences/{geofenceId} {
      // Managers and admins can create geofences
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isManager();
      
      // All users in tenant can read geofences
      allow read: if isAuthenticated() && sameTenant(resource.data.tenantId);
      
      // Managers and admins can update geofences
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
      
      // Managers and admins can delete geofences
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
    }
    
    // ===== ALERT SYSTEM COLLECTIONS =====
    
    // Alerts Collection
    match /alerts/{alertId} {
      // Admins can create alerts
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isAdmin();
      
      // Users in tenant can read alerts sent to them
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId);
      
      // Admins can update alerts (e.g., deactivate)
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      // Only admins can delete alerts
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
    }
    
    // Alert Responses Collection
    match /alert_responses/{responseId} {
      // Any authenticated user can create a response to an alert in their tenant
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can read their own responses, admins can read all responses in tenant
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admins can update responses (e.g., mark as read)
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      // Responses cannot be deleted (audit trail)
      allow delete: if false;
    }
    
    // User Alert Status Collection
    match /user_alert_status/{statusId} {
      // System creates status when alert is sent, or user creates when opening alert
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can read their own status, admins can read all statuses
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can update their own status, admins can update any status
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      (resource.data.userId == request.auth.uid || isAdmin());
      
      // Status cannot be deleted
      allow delete: if false;
    }
    
    // Licenses Collection (for license key management)
    match /licenses/{licenseId} {
      // Only super admins can create licenses
      allow create: if isSuperAdmin();
      
      // Admins can read licenses for their tenant
      allow read: if isAuthenticated() && 
                    (isSuperAdmin() || 
                     (sameTenant(resource.data.tenantId) && isAdmin()));
      
      // Only super admins can update licenses
      allow update: if isSuperAdmin();
      
      // Only super admins can delete licenses
      allow delete: if isSuperAdmin();
    }
  }
}
