rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function sameTenant(tenantId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function hasAnyRole(roles) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }
    
    function isSuperAdmin() {
      return hasRole('super_admin');
    }
    
    function isAdmin() {
      return hasAnyRole(['admin', 'super_admin']);
    }
    
    function isManager() {
      return hasAnyRole(['manager', 'admin', 'super_admin']);
    }
    
    // Users Collection
    match /users/{userId} {
      allow create: if isOwner(userId) && 
                      request.resource.data.keys().hasAll(['email', 'fullName', 'tenantId', 'role', 'isActive']);
      
      allow read: if isOwner(userId) || 
                    (isAuthenticated() && sameTenant(resource.data.tenantId));
      
      allow list: if isAuthenticated() && request.query.limit <= 1;
      
      allow update: if (isOwner(userId) && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt', 'lastCheckInAt', 'nextCheckInDue', 'lastCheckInStatus', 'inEmergency', 'lastSOSTime'])) ||
                      (isAuthenticated() && 
                       sameTenant(resource.data.tenantId) && 
                       hasAnyRole(['admin', 'super_admin']));
      
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      hasAnyRole(['admin', 'super_admin']);
    }
    
    // Tenants Collection
    match /tenants/{tenantId} {
      allow create: if isAuthenticated() && 
                      request.resource.data.adminId == request.auth.uid;
      
      allow read: if isAuthenticated() && sameTenant(tenantId);
      
      allow update: if isAuthenticated() && 
                      sameTenant(tenantId) && 
                      hasAnyRole(['admin', 'super_admin']);
      
      allow delete: if isSuperAdmin();
    }
    
    // Invitations Collection
    match /invitations/{invitationId} {
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isManager();
      
      allow read: if true;
      
      allow update: if isAuthenticated();
      
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
    }
    
    // Locations Collection
    match /locations/{userId} {
      allow create, update: if isOwner(userId) && 
                              isAuthenticated() && 
                              sameTenant(request.resource.data.tenantId);
      
      allow read: if isAuthenticated() && sameTenant(resource.data.tenantId);
      
      allow list: if isAuthenticated() && isManager();
      
      allow delete: if false;
    }
    
    // Geofences Collection
    match /geofences/{geofenceId} {
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isManager();
      
      allow read: if isAuthenticated() && sameTenant(resource.data.tenantId);
      
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
      
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isManager();
    }
    
    // ===== ALERT SYSTEM COLLECTIONS =====
    
    // Alerts Collection
    match /alerts/{alertId} {
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      isAdmin();
      
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId);
      
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      allow delete: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
    }
    
    // Alert Responses Collection
    match /alert_responses/{responseId} {
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      allow delete: if false;
    }
    
    // User Alert Status Collection
    match /user_alert_status/{statusId} {
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      (resource.data.userId == request.auth.uid || isAdmin());
      
      allow delete: if false;
    }
    
    // ===== PHASE 1 SAFETY FEATURES =====
    
    // SOS Alerts Collection
    match /sos_alerts/{sosId} {
      // Field personnel can create SOS alerts
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can read their own SOS, admins can read all in tenant
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admins can query all SOS in tenant
      allow list: if isAuthenticated() && 
                    sameTenant(request.resource.data.tenantId) && 
                    isAdmin();
      
      // Users can update their own SOS (cancel), admins can update any
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      (resource.data.userId == request.auth.uid || isAdmin());
      
      // SOS cannot be deleted (audit trail)
      allow delete: if false;
    }
    
    // Safety Check-ins Collection
    match /safety_checkins/{checkinId} {
      // Field personnel can create check-ins
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can read their own check-ins, admins can read all
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admins can query check-ins in their tenant
      allow list: if isAuthenticated() && 
                    sameTenant(request.resource.data.tenantId) && 
                    isAdmin();
      
      // Check-ins cannot be updated or deleted (audit trail)
      allow update: if false;
      allow delete: if false;
    }
    
    // Incident Reports Collection
    match /incident_reports/{incidentId} {
      // Any authenticated user can create incident reports
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId) && 
                      request.resource.data.reporterId == request.auth.uid;
      
      // Users can read their own reports, admins can read all in tenant
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.reporterId == request.auth.uid || isAdmin());
      
      // Admins can query all incidents in their tenant
      allow list: if isAuthenticated() && 
                    sameTenant(request.resource.data.tenantId) && 
                    isAdmin();
      
      // Admins can update incidents (review, status)
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      // Incidents cannot be deleted (audit trail)
      allow delete: if false;
    }
    
    // Geofence Breaches Collection
    match /geofence_breaches/{breachId} {
      // System creates breaches (allow authenticated users for now)
      allow create: if isAuthenticated() && 
                      sameTenant(request.resource.data.tenantId);
      
      // Users can read their own breaches, admins can read all
      allow read: if isAuthenticated() && 
                    sameTenant(resource.data.tenantId) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      
      // Admins can query all breaches
      allow list: if isAuthenticated() && 
                    sameTenant(request.resource.data.tenantId) && 
                    isAdmin();
      
      // Admins can acknowledge breaches
      allow update: if isAuthenticated() && 
                      sameTenant(resource.data.tenantId) && 
                      isAdmin();
      
      // Breaches cannot be deleted (audit trail)
      allow delete: if false;
    }
    
    // Licenses Collection (for license key management)
    match /licenses/{licenseId} {
      allow create: if isSuperAdmin();
      
      allow read: if isAuthenticated() && 
                    (isSuperAdmin() || 
                     (sameTenant(resource.data.tenantId) && isAdmin()));
      
      allow update: if isSuperAdmin();
      
      allow delete: if isSuperAdmin();
    }
  }
}
